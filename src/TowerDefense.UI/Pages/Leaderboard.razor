@page "/leaderboard"
@inject LeaderboardService LeaderboardSvc

<div class="leaderboard-page">
    <h1>Leaderboard</h1>
    <a href="/">← Back to Menu</a>
    <table class="scores-table">
        <thead>
            <tr><th>Rank</th><th>Player</th><th>Score</th><th>Wave</th><th>Date</th></tr>
        </thead>
        <tbody>
            @{ int rank = 1; }
            @foreach (var e in LeaderboardSvc.TopScores)
            {
                <tr>
                    <td>@rank++</td>
                    <td>@e.PlayerName</td>
                    <td>@e.Score</td>
                    <td>@e.Wave</td>
                    <td>@e.Date.ToLocalTime().ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>
