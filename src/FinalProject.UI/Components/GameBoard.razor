@using FinalProject.Core

<div class="board">
    @for (int r = 0; r < GameState.Map.Rows; r++)
    {
        <div class="row">
            @for (int c = 0; c < GameState.Map.Cols; c++)
            {
                var pos = new GridPosition(r, c);
                <div class="tile" @onclick="() => PlaceTower(pos)">
                    @RenderTile(pos)
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public GameState GameState { get; set; } = default!;

    private void PlaceTower(GridPosition pos)
    {
        if (!GameState.OccupiedTiles.Contains(pos) && GameState.Gold >= 50)
        {
            var tower = new Tower
            {
                Id = GameState.Towers.Count + 1,
                Position = pos
            };

            GameState.Towers.Add(tower.Id, tower);
            GameState.OccupiedTiles.Add(pos);
            GameState.Gold -= tower.Cost;
        }
    }

    private RenderFragment RenderTile(GridPosition pos) => builder =>
    {
        if (GameState.OccupiedTiles.Contains(pos))
            builder.AddContent(0, "🛡");
        else
            builder.AddContent(0, ".");
    };
}
